generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AgeBand {
  AGE_4_5
  AGE_6_7
  AGE_8_9
  AGE_10_11
}

enum Subject {
  READING
  MATHS
  SCIENCE
}

enum SessionMode {
  DAILY_SESSION
  LIVE_TUTOR
  STORY_MODE
  HOMEWORK_HELP
}

enum SessionStatus {
  CREATED
  ACTIVE
  PAUSED
  AWAITING_INPUT
  PROCESSING
  COMPLETED
  CANCELLED
  SAFETY_PAUSED
}

enum ActorType {
  CHILD
  PARENT
  SYSTEM
}

enum SafetySeverity {
  INFO
  WARNING
  HIGH
  CRITICAL
}

enum ReviewStatus {
  OPEN
  REVIEWED
}

enum HomeworkSourceType {
  IMAGE
  TEXT
}

model ParentAccount {
  id                String      @id @default(cuid())
  email             String      @unique
  authProvider      String
  createdAt         DateTime    @default(now())
  locale            String
  subscriptionStatus String
  households        Household[]
}

model Household {
  id           String        @id @default(cuid())
  ownerParentId String
  settingsJson Json
  createdAt    DateTime      @default(now())
  owner        ParentAccount @relation(fields: [ownerParentId], references: [id])
  children     ChildProfile[]
}

model ChildProfile {
  id                     String          @id @default(cuid())
  householdId            String
  displayName            String
  birthDate              DateTime
  ageBand                AgeBand
  schoolYear             String
  avatarUrl              String?
  accessibilitySettingsJson Json
  permissionsJson        Json
  createdAt              DateTime        @default(now())
  household              Household       @relation(fields: [householdId], references: [id])
  learnerStates          LearnerState[]
  sessions               Session[]
  assessments            AssessmentResult[]
  safetyEvents           SafetyEvent[]
  stories                StoryInstance[]
  homeworkArtifacts      HomeworkArtifact[]
}

model LearnerState {
  id                   String   @id @default(cuid())
  childProfileId       String
  subject              Subject
  masteryMapJson       Json
  confidenceMapJson    Json
  misconceptionLogJson Json
  interestTagsJson     Json
  preferredModesJson   Json
  sessionTolerance     Int
  updatedAt            DateTime @updatedAt
  childProfile         ChildProfile @relation(fields: [childProfileId], references: [id])

  @@index([childProfileId, subject])
}

model CurriculumNode {
  id               String   @id
  subject          Subject
  ageBand          AgeBand
  skillCode        String
  title            String
  description      String
  prerequisitesJson Json
  difficulty       Int
  metadataJson     Json
  version          String
  sessions         Session[]
  assessments      AssessmentResult[]
  stories          StoryInstance[]

  @@index([subject, ageBand])
}

model Session {
  id            String       @id @default(cuid())
  childProfileId String
  mode          SessionMode
  status        SessionStatus
  goalNodeId    String?
  startedAt     DateTime     @default(now())
  endedAt       DateTime?
  durationSeconds Int?
  summaryJson   Json
  childProfile  ChildProfile @relation(fields: [childProfileId], references: [id])
  goalNode      CurriculumNode? @relation(fields: [goalNodeId], references: [id])
  turns         SessionTurn[]
  safetyEvents  SafetyEvent[]
  assessments   AssessmentResult[]
  homeworkArtifacts HomeworkArtifact[]

  @@index([childProfileId, status])
}

model SessionTurn {
  id           String      @id @default(cuid())
  sessionId    String
  actor        ActorType
  contentJson  Json
  safetyStatus String
  createdAt    DateTime    @default(now())
  session      Session     @relation(fields: [sessionId], references: [id])

  @@index([sessionId, createdAt])
}

model AssessmentResult {
  id               String   @id @default(cuid())
  childProfileId   String
  sessionId        String?
  curriculumNodeId String?
  performanceType  String
  score            Float
  confidenceEstimate Float
  createdAt        DateTime @default(now())
  childProfile     ChildProfile @relation(fields: [childProfileId], references: [id])
  session          Session?     @relation(fields: [sessionId], references: [id])
  curriculumNode   CurriculumNode? @relation(fields: [curriculumNodeId], references: [id])

  @@index([childProfileId, createdAt])
}

model SafetyEvent {
  id             String        @id @default(cuid())
  childProfileId String
  sessionId      String?
  severity       SafetySeverity
  type           String
  triggerExcerpt String
  systemAction   String
  reviewStatus   ReviewStatus
  createdAt      DateTime      @default(now())
  childProfile   ChildProfile  @relation(fields: [childProfileId], references: [id])
  session        Session?      @relation(fields: [sessionId], references: [id])

  @@index([childProfileId, severity])
}

model StoryInstance {
  id               String   @id @default(cuid())
  childProfileId   String
  curriculumNodeId String
  title            String
  branchStateJson  Json
  progressJson     Json
  childProfile     ChildProfile @relation(fields: [childProfileId], references: [id])
  curriculumNode   CurriculumNode @relation(fields: [curriculumNodeId], references: [id])

  @@index([childProfileId, curriculumNodeId])
}

model HomeworkArtifact {
  id                String            @id @default(cuid())
  childProfileId    String
  sessionId         String?
  sourceType        HomeworkSourceType
  blobUrl           String
  extractedText     String
  parsedStructureJson Json
  createdAt         DateTime          @default(now())
  childProfile      ChildProfile      @relation(fields: [childProfileId], references: [id])
  session           Session?          @relation(fields: [sessionId], references: [id])

  @@index([childProfileId, createdAt])
}

model AuditEvent {
  id          String   @id @default(cuid())
  actorType   String
  actorId     String
  eventType   String
  payloadJson Json
  createdAt   DateTime @default(now())
}
